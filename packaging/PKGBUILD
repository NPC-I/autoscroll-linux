# Maintainer: autoscroll-linux contributors <root@localhost>
pkgname=autoscroll
pkgver=1.0.0
pkgrel=1
pkgdesc="System-wide Windows-style middle-click autoscroll for Linux"
arch=('x86_64' 'aarch64')
url="https://github.com/talos/autoscroll-linux"
license=('MIT')
depends=('glibc')
makedepends=('cmake' 'gcc')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/talos/autoscroll-linux/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cmake -B build -DBUILD_TESTS=ON
    cmake --build build
}

check() {
    ctest --test-dir build
}

package() {
    DESTDIR="${pkgdir}" cmake --install build
    install -Dm644 service/autoscroll.service "${pkgdir}/usr/lib/systemd/system/autoscroll.service"
    install -Dm644 udev/99-autoscroll.rules "${pkgdir}/usr/lib/udev/rules.d/99-autoscroll.rules"
    install -Dm644 man/autoscroll.1 "${pkgdir}/usr/share/man/man1/autoscroll.1"
}
